# Copy this file to `.env` and fill in your own values. Never commit `.env`.

# IMAP — use an app-specific password, never your real account password.
# HERMES_IMAP_PROVIDER = gmail | icloud
HERMES_IMAP_PROVIDER=gmail
HERMES_IMAP_USER=you@gmail.com
HERMES_IMAP_APP_PASSWORD=your-app-specific-password
# HERMES_IMAP_HOST_OVERRIDE=imap.example.com
# HERMES_IMAP_PORT=993
# HERMES_IMAP_MAILBOX=INBOX

# Telegram — create a bot with @BotFather, then message @userinfobot to get your chat id.
HERMES_TELEGRAM_BOT_TOKEN=123456:your-bot-token
HERMES_TELEGRAM_CHAT_ID=your-telegram-chat-id

# LLM (used starting Phase 2 — see hermes/tools/llm.py)
HERMES_LLM_API_KEY=
HERMES_LLM_MODEL=gpt-4o-mini
# HERMES_LLM_BASE_URL=

# Scout polling interval, in seconds
HERMES_EMAIL_POLL_INTERVAL_SECONDS=180
