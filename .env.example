# Copy this file to `.env` and fill in your own values. Never commit `.env`.

# IMAP — use an app-specific password, never your real account password.
# ULYSSES_IMAP_PROVIDER = gmail | icloud
ULYSSES_IMAP_PROVIDER=gmail
ULYSSES_IMAP_USER=you@gmail.com
ULYSSES_IMAP_APP_PASSWORD=your-app-specific-password
# ULYSSES_IMAP_HOST_OVERRIDE=imap.example.com
# ULYSSES_IMAP_PORT=993
# ULYSSES_IMAP_MAILBOX=INBOX

# Telegram — create a bot with @BotFather, then message @userinfobot to get your chat id.
ULYSSES_TELEGRAM_BOT_TOKEN=123456:your-bot-token
ULYSSES_TELEGRAM_CHAT_ID=your-telegram-chat-id

# LLM (used starting Phase 2 — see ulysses/tools/llm.py)
ULYSSES_LLM_API_KEY=
ULYSSES_LLM_MODEL=gpt-4o-mini
# ULYSSES_LLM_BASE_URL=

# Scout polling interval, in seconds
ULYSSES_EMAIL_POLL_INTERVAL_SECONDS=180
